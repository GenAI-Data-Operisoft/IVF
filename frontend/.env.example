# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# API Gateway endpoint
REACT_APP_API_BASE_URL=https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com/prod

# Cognito
REACT_APP_USER_POOL_ID=YOUR_REGION_XXXXXXXX
REACT_APP_USER_POOL_CLIENT_ID=your_client_id_here

# CloudFront CDN base URL (for static assets)
REACT_APP_CDN_URL=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
